# Telegram bot token from @BotFather (required)
BOT_TOKEN=123456:ABC-your-token-here

# Solana RPC. Public endpoint works but rate-limits the richer signals.
# A free Helius URL is strongly recommended for the live demo:
#   https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_RPC_URL=

# Path to the skill repo (for the /watch command, which shells out to its
# watch_deployments.ts script). Defaults to a sibling directory.
SKILL_DIR=../scry-skill
